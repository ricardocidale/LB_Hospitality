{
  "name": "elevenlabs_libraries",
  "description": "Deterministic reference for all ElevenLabs official and third-party SDK libraries, packages, and their package managers.",
  "source": "https://elevenlabs.io/docs/eleven-api/resources/libraries",
  "official_rest_api": {
    "python": {
      "github": "https://github.com/elevenlabs/elevenlabs-python",
      "package": "elevenlabs",
      "manager": "PyPI",
      "install": "pip install elevenlabs"
    },
    "javascript_node": {
      "github": "https://github.com/elevenlabs/elevenlabs-js",
      "package": "@elevenlabs/elevenlabs-js",
      "manager": "npm",
      "install": "npm install elevenlabs",
      "note": "Server-side Node.js SDK — used in this project for TTS, STT, agent management"
    }
  },
  "official_agents_platform": {
    "javascript": {
      "docs": "https://elevenlabs.io/docs/agents-platform/libraries/java-script",
      "package": "@elevenlabs/client",
      "manager": "npm",
      "install": "npm install @elevenlabs/client",
      "description": "Vanilla JS/TS browser SDK for Conversational AI"
    },
    "react": {
      "docs": "https://elevenlabs.io/docs/agents-platform/libraries/react",
      "package": "@elevenlabs/react",
      "manager": "npm",
      "install": "npm install @elevenlabs/react",
      "description": "React hooks (useConversation) for Conversational AI"
    },
    "react_native": {
      "docs": "https://elevenlabs.io/docs/agents-platform/libraries/react-native",
      "package": "@elevenlabs/react-native",
      "manager": "npm",
      "install": "npm install @elevenlabs/react-native",
      "description": "React Native SDK for mobile agents"
    },
    "python_agents": {
      "docs": "https://elevenlabs.io/docs/agents-platform/libraries/python",
      "package": "elevenlabs",
      "manager": "PyPI",
      "description": "Python SDK for agents platform"
    },
    "swift": {
      "docs": "https://elevenlabs.io/docs/agents-platform/libraries/swift",
      "github": "https://github.com/elevenlabs/ElevenLabsSwift",
      "description": "iOS/macOS Swift SDK"
    },
    "kotlin": {
      "docs": "https://elevenlabs.io/docs/agents-platform/libraries/kotlin",
      "package": "io.elevenlabs:elevenlabs-android",
      "manager": "Maven",
      "description": "Android Kotlin SDK"
    },
    "flutter": {
      "docs": "https://github.com/elevenlabs/elevenlabs-flutter",
      "package": "elevenlabs_agents",
      "manager": "Pub",
      "description": "Flutter/Dart SDK for agents"
    }
  },
  "third_party": {
    "vercel_ai_sdk": {
      "docs": "https://elevenlabs.io/docs/developers/guides/cookbooks/speech-to-text/batch/vercel-ai-sdk",
      "package": "ai",
      "manager": "npm"
    },
    "dotnet": {
      "docs": "https://github.com/RageAgainstThePixel/ElevenLabs-DotNet",
      "package": "ElevenLabs-DotNet",
      "manager": "NuGet"
    },
    "unity": {
      "docs": "https://github.com/RageAgainstThePixel/com.rest.elevenlabs",
      "package": "com.rest.elevenlabs",
      "manager": "OpenUPM"
    }
  },
  "ui_library": {
    "name": "ElevenLabs UI",
    "source": "https://github.com/elevenlabs/ui",
    "docs": "https://ui.elevenlabs.io",
    "cli": "@elevenlabs/cli",
    "install": "npx @elevenlabs/cli@latest components add <component>",
    "description": "Open-source React component library (shadcn-based) for agent UIs, waveforms, voice controls",
    "component_count": 17,
    "skill_ref": ".claude/skills/elevenlabs/ui/SKILL.md"
  },
  "widget_packages": {
    "convai_widget_core": {
      "package": "@elevenlabs/convai-widget-core",
      "description": "Web component for drop-in widget embed (React apps)",
      "note": "Currently used in this project for Marcela widget"
    },
    "convai_widget_embed": {
      "package": "@elevenlabs/convai-widget-embed",
      "description": "CDN script for simple HTML page embed"
    }
  },
  "this_project_uses": [
    "elevenlabs (server — TTS, STT, agent management)",
    "@elevenlabs/convai-widget-core (client — Marcela widget)",
    "@elevenlabs/react (client — available for useConversation upgrade)"
  ],
  "skill_ref": ".claude/skills/elevenlabs/docs/overview.md"
}
