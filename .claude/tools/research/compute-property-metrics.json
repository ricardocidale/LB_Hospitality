{
  "name": "compute_property_metrics",
  "description": "Compute exact financial metrics for a property: RevPAR, room revenue, total revenue, GOP, NOI margin, revenue per room. Use this to validate research recommendations against deterministic math.",
  "input_schema": {
    "type": "object",
    "properties": {
      "room_count": { "type": "integer", "description": "Number of rooms" },
      "adr": { "type": "number", "description": "Average daily rate in dollars" },
      "occupancy": { "type": "number", "description": "Occupancy rate as decimal (e.g., 0.70 for 70%)" },
      "cost_rate_rooms": { "type": "number", "description": "Room department cost rate (default 0.36)" },
      "cost_rate_fb": { "type": "number", "description": "F&B cost rate (default 0.32)" },
      "cost_rate_admin": { "type": "number", "description": "Admin & General rate (default 0.08)" },
      "cost_rate_marketing": { "type": "number", "description": "Marketing rate (default 0.05)" },
      "cost_rate_property_ops": { "type": "number", "description": "Property ops rate (default 0.04)" },
      "cost_rate_utilities": { "type": "number", "description": "Utilities rate (default 0.05)" },
      "cost_rate_ffe": { "type": "number", "description": "FF&E reserve rate (default 0.04)" },
      "cost_rate_other": { "type": "number", "description": "Other costs rate (default 0.05)" },
      "rev_share_events": { "type": "number", "description": "Event revenue as % of room revenue (default 0.43)" },
      "rev_share_fb": { "type": "number", "description": "F&B revenue as % of room revenue (default 0.22)" },
      "rev_share_other": { "type": "number", "description": "Other revenue as % of room revenue (default 0.07)" },
      "catering_boost_pct": { "type": "number", "description": "Catering boost % (default 0.30)" },
      "base_management_fee_rate": { "type": "number", "description": "Base management fee rate (default 0.05)" },
      "incentive_management_fee_rate": { "type": "number", "description": "Incentive fee rate (default 0.15)" }
    },
    "required": ["room_count", "adr", "occupancy"]
  }
}
