{
  "name": "elevenlabs-widget-config",
  "description": "Deterministic reference for the ElevenLabs Conversational AI widget integration. Covers file map, auth flow, admin config, and voice IDs.",
  "package": "@elevenlabs/convai-widget-core",
  "web_component": "<elevenlabs-convai>",
  "files": {
    "widget_component": "client/src/components/ElevenLabsWidget.tsx",
    "type_declarations": "client/src/elevenlabs-convai.d.ts",
    "layout_gating": "client/src/components/Layout.tsx",
    "signed_url_endpoint": "server/routes/admin/marcela.ts",
    "elevenlabs_integration": "server/integrations/elevenlabs.ts",
    "admin_tab": "client/src/components/admin/marcela/MarcelaTab.tsx",
    "admin_types": "client/src/components/admin/marcela/types.ts"
  },
  "db_field": {
    "table": "global_assumptions",
    "column": "marcela_agent_id",
    "ts_field": "marcelaAgentId",
    "type": "text",
    "default": ""
  },
  "api_endpoints": {
    "signed_url": {
      "method": "GET",
      "path": "/api/marcela/signed-url",
      "auth": "requireAuth (any logged-in user)",
      "response": { "signedUrl": "wss://..." },
      "upstream": "GET https://api.elevenlabs.io/v1/convai/conversation/get-signed-url?agent_id=<ID>"
    }
  },
  "voices": {
    "english": { "name": "Jessica", "id": "cgSgspJ2msm6clMCkdW9" },
    "portuguese": { "name": "Sarah", "id": "EXAVITQu4vr4xnSDxMaL" },
    "spanish": { "name": "configurable", "id": "set on ElevenLabs dashboard" }
  },
  "gating_conditions": [
    "showAiAssistant === true",
    "marcelaAgentId is non-empty",
    "tourActive === false",
    "promptVisible === false"
  ],
  "widget_attributes": {
    "url": "Signed WebSocket URL (required for private agents)",
    "agent-id": "Public agent ID (alternative to url, not used in this integration)"
  }
}
