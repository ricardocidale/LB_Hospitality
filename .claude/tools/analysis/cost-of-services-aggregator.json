{
  "name": "cost_of_services_aggregator",
  "description": "Aggregate cost of centralized services for the management company. Takes per-category fee amounts and service templates, computes vendor costs and gross profit for each category based on service model (centralized vs direct) and markup.",
  "parameters": {
    "type": "object",
    "properties": {
      "feesByCategory": {
        "type": "object",
        "description": "Map of service category name to monthly fee amount (from ServiceFeeBreakdown.byCategory)",
        "additionalProperties": { "type": "number" }
      },
      "templates": {
        "type": "array",
        "description": "Active company service templates",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "number" },
            "name": { "type": "string" },
            "defaultRate": { "type": "number" },
            "serviceModel": { "type": "string", "enum": ["centralized", "direct"] },
            "serviceMarkup": { "type": "number", "description": "Cost-plus markup (e.g., 0.20 = 20%)" },
            "isActive": { "type": "boolean" },
            "sortOrder": { "type": "number" }
          },
          "required": ["id", "name", "serviceModel", "serviceMarkup", "isActive"]
        }
      }
    },
    "required": ["feesByCategory", "templates"]
  },
  "returns": {
    "type": "object",
    "properties": {
      "byCategory": {
        "type": "object",
        "description": "Per-category breakdown: name, revenue, vendorCost, grossProfit, serviceModel, markup"
      },
      "centralizedRevenue": { "type": "number", "description": "Total revenue from centralized services" },
      "directRevenue": { "type": "number", "description": "Total revenue from direct services" },
      "totalVendorCost": { "type": "number", "description": "Total vendor cost (centralized only)" },
      "totalGrossProfit": { "type": "number", "description": "Total gross profit (revenue - vendor cost)" }
    }
  },
  "handler": "calc/services/cost-of-services.ts:computeCostOfServices"
}
