{
  "name": "help-page-structure",
  "description": "Deterministic lookup of Help page tab structure, visibility rules, and routes. Use instead of reading Help.tsx.",
  "file": "client/src/pages/Help.tsx",
  "route": "/help",
  "legacy_redirect": "/methodology",
  "tabs": [
    {
      "label": "User Manual",
      "value": "user-manual",
      "visible_to": "all authenticated users",
      "default": true,
      "content_source": "client/src/pages/user-manual/index.tsx",
      "total_sections": 17,
      "skill_ref": ".claude/manuals/user-manual/SKILL.md"
    },
    {
      "label": "Checker Manual",
      "value": "checker-manual",
      "visible_to": "admin and checker roles only",
      "default": false,
      "content_source": "client/src/pages/checker-manual/index.tsx",
      "total_sections": 21,
      "skill_ref": ".claude/manuals/checker-manual/SKILL.md"
    },
    {
      "label": "Guided Tour",
      "value": "guided-tour",
      "visible_to": "all authenticated users",
      "default": false,
      "content_source": "inline in Help.tsx",
      "features": [
        "Start Tour button → setTourActive(true)",
        "Do not show again toggle → PATCH /api/profile/tour-prompt"
      ],
      "skill_ref": ".claude/skills/tour/SKILL.md"
    }
  ],
  "role_check": {
    "admin": "useAuth().isAdmin",
    "checker": "user.role includes 'checker'"
  }
}
