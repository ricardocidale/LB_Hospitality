{
  "name": "elevenlabs_ui_voice_picker",
  "description": "Deterministic reference for the ElevenLabs Voice Picker component — searchable voice selector dropdown with audio preview and orb visualization.",
  "component": "VoicePicker",
  "source": "https://github.com/elevenlabs/ui",
  "install": "npx @elevenlabs/cli@latest components add voice-picker",
  "target_path": "client/src/components/ui/elevenlabs/voice-picker.tsx",
  "peer_dependencies": ["orb component"],
  "props": {
    "voices": { "type": "ElevenLabs.Voice[]", "description": "Array of voice objects from ElevenLabs API" },
    "value": { "type": "string", "description": "Currently selected voice ID" },
    "onValueChange": { "type": "(value: string) => void", "description": "Called when selection changes" },
    "open": { "type": "boolean", "description": "Controls dropdown open state" },
    "onOpenChange": { "type": "(open: boolean) => void", "description": "Called when open state changes" },
    "placeholder": { "type": "string", "default": "Select a voice...", "description": "Placeholder text" }
  },
  "features": ["Searchable voice list", "Audio preview playback", "Orb animation during preview", "Voice metadata display", "Keyboard navigation"],
  "skill_ref": ".claude/skills/elevenlabs/ui/voice-picker.md"
}
