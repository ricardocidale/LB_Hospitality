{
  "name": "capex_reserve",
  "description": "Project FF&E (Furniture, Fixtures & Equipment) reserve adequacy over a hold period. Models annual contributions from revenue, planned replacement cycles for specific asset categories, and flags years where the reserve may be underfunded. Ensures compliance with brand standards and lender reserve requirements.",
  "input_schema": {
    "type": "object",
    "properties": {
      "property_name": {
        "type": "string",
        "description": "Property identifier for reporting"
      },
      "room_count": {
        "type": "integer",
        "description": "Number of rooms (used for per-key metrics)"
      },
      "annual_revenue": {
        "type": "number",
        "description": "Current annual total revenue"
      },
      "ffe_reserve_rate": {
        "type": "number",
        "description": "FF&E reserve contribution as percentage of revenue (default 0.04 = 4%)",
        "default": 0.04
      },
      "initial_reserve_balance": {
        "type": "number",
        "description": "Starting reserve fund balance (default 0)",
        "default": 0
      },
      "hold_period_years": {
        "type": "integer",
        "description": "Number of years to project"
      },
      "revenue_growth_rate": {
        "type": "number",
        "description": "Annual revenue growth rate as decimal (default 0.03)",
        "default": 0.03
      },
      "capex_categories": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "label": { "type": "string", "description": "Category name (e.g. 'Soft Goods', 'Case Goods')" },
            "useful_life_years": { "type": "integer", "description": "Expected useful life before replacement" },
            "replacement_cost": { "type": "number", "description": "Cost to replace this category" },
            "current_age": { "type": "integer", "description": "Current age in years" }
          },
          "required": ["label", "useful_life_years", "replacement_cost", "current_age"]
        },
        "description": "CapEx categories with replacement cycles"
      },
      "inflation_rate": {
        "type": "number",
        "description": "Annual inflation rate for replacement cost escalation (default 0.03)",
        "default": 0.03
      }
    },
    "required": ["room_count", "annual_revenue", "hold_period_years"]
  }
}
