{
  "name": "elevenlabs_ui_message",
  "description": "Deterministic reference for the ElevenLabs Message component — composable chat bubble with avatar, role-based alignment, and visual variants.",
  "components": {
    "Message": {
      "description": "Root — sets role context",
      "props": {
        "from": {
          "type": "\"user\" | \"assistant\"",
          "description": "Determines alignment and styling"
        }
      }
    },
    "MessageContent": {
      "description": "Text bubble",
      "props": {
        "variant": {
          "type": "\"contained\" | \"flat\"",
          "default": "contained",
          "description": "contained = bubble background; flat = no background"
        }
      }
    },
    "MessageAvatar": {
      "description": "Optional avatar image",
      "props": {
        "src": { "type": "string", "description": "Avatar image URL" },
        "name": { "type": "string", "description": "Alt text / fallback initials" }
      }
    },
    "MessageActions": {
      "description": "Action buttons container (copy, feedback, etc.)"
    }
  },
  "source": "https://github.com/elevenlabs/ui",
  "install": "npx @elevenlabs/cli@latest components add message",
  "target_path": "client/src/components/ui/elevenlabs/message.tsx",
  "peer_dependencies": [],
  "alignment": {
    "user": "Right-aligned, accent color background",
    "assistant": "Left-aligned, subtle/transparent background"
  },
  "conventions": {
    "user_messages": "variant=\"contained\"",
    "assistant_messages": "variant=\"flat\" with MessageAvatar"
  },
  "skill_ref": ".claude/skills/elevenlabs/ui/message.md"
}
