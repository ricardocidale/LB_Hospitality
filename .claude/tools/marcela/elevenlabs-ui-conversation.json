{
  "name": "elevenlabs_ui_conversation",
  "description": "Deterministic reference for the ElevenLabs Conversation component — scrolling chat container with auto-scroll, sticky-to-bottom, and empty state.",
  "components": {
    "Conversation": {
      "description": "Root scrollable container",
      "props": {
        "className": { "type": "string", "description": "Custom styling (set explicit height)" }
      }
    },
    "ConversationContent": {
      "description": "Scrollable message area inside Conversation"
    },
    "ConversationEmptyState": {
      "description": "Placeholder when no messages exist",
      "props": {
        "title": { "type": "string", "description": "Empty state heading" },
        "description": { "type": "string", "description": "Subtext" },
        "icon": { "type": "ReactNode", "description": "Custom icon" }
      }
    },
    "ConversationScrollButton": {
      "description": "Jump-to-latest button, auto-shows when scrolled up"
    }
  },
  "source": "https://github.com/elevenlabs/ui",
  "install": "npx @elevenlabs/cli@latest components add conversation",
  "target_path": "client/src/components/ui/elevenlabs/conversation.tsx",
  "peer_dependencies": ["use-stick-to-bottom"],
  "behavior": {
    "auto_scroll": "New messages auto-scroll to bottom",
    "sticky": "Stays pinned to bottom as messages arrive",
    "scroll_button": "Appears when user scrolls up, returns to bottom on click",
    "overflow": "Vertical scroll, horizontal clip"
  },
  "composition_pattern": [
    "<Conversation className=\"h-[600px]\">",
    "  <ConversationContent>",
    "    {messages.map(msg => <Message key={msg.id} from={msg.role}>...</Message>)}",
    "  </ConversationContent>",
    "  <ConversationScrollButton />",
    "</Conversation>"
  ],
  "glass_styling": "bg-black/20 backdrop-blur-xl border border-white/10 rounded-2xl",
  "skill_ref": ".claude/skills/elevenlabs/ui/conversation.md"
}
