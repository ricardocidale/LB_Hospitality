{
  "name": "elevenlabs_ui_waveform",
  "description": "Deterministic reference for ElevenLabs waveform/visualization components — Waveform, ScrollingWaveform, AudioScrubber, MicrophoneWaveform, LiveWaveform, BarVisualizer. All Canvas API based.",
  "components": {
    "Waveform": {
      "description": "Static waveform from data array",
      "install": "npx @elevenlabs/cli@latest components add waveform",
      "props": {
        "data": { "type": "number[]", "description": "Values 0–1 for each bar" },
        "barWidth": { "type": "number", "default": 4 },
        "barGap": { "type": "number", "default": 2 },
        "barColor": { "type": "string", "default": "foreground" },
        "fadeEdges": { "type": "boolean", "default": true },
        "height": { "type": "string | number", "default": 128 }
      }
    },
    "ScrollingWaveform": {
      "description": "Continuously scrolling animated waveform (no data required)",
      "props": {
        "speed": { "type": "number", "default": 50, "description": "Scroll speed px/s" },
        "barCount": { "type": "number", "default": 60 },
        "barWidth": { "type": "number", "default": 4 },
        "barGap": { "type": "number", "default": 2 },
        "barColor": { "type": "string", "default": "foreground" }
      }
    },
    "AudioScrubber": {
      "description": "Playback position scrubber synced to audio time",
      "props": {
        "currentTime": { "type": "number", "description": "Seconds" },
        "duration": { "type": "number", "description": "Seconds" },
        "onSeek": { "type": "(time: number) => void" }
      }
    },
    "MicrophoneWaveform": {
      "description": "Real-time microphone input visualization (Web Audio API AnalyserNode)",
      "props": {
        "active": { "type": "boolean", "description": "Whether mic is recording" },
        "barColor": { "type": "string" }
      }
    },
    "LiveWaveform": {
      "description": "Real-time smooth scrolling audio visualization",
      "install": "npx @elevenlabs/cli@latest components add live-waveform"
    },
    "BarVisualizer": {
      "description": "Frequency-domain bar visualization (equalizer style)",
      "install": "npx @elevenlabs/cli@latest components add bar-visualizer",
      "props": {
        "barCount": { "type": "number", "default": 32 },
        "height": { "type": "number", "default": 64 },
        "barColor": { "type": "string" }
      }
    }
  },
  "source": "https://github.com/elevenlabs/ui",
  "target_paths": {
    "waveform": "client/src/components/ui/elevenlabs/waveform.tsx",
    "live_waveform": "client/src/components/ui/elevenlabs/live-waveform.tsx",
    "bar_visualizer": "client/src/components/ui/elevenlabs/bar-visualizer.tsx"
  },
  "peer_dependencies": [],
  "rendering": "Canvas API at 60fps via requestAnimationFrame, auto-cleanup on unmount",
  "marcela_color": "#9FBCA4",
  "skill_ref": ".claude/skills/elevenlabs/ui/waveform.md"
}
