{
  "name": "elevenlabs_ui_orb",
  "description": "Deterministic reference for the ElevenLabs Orb component — 3D animated orb with agent state visualization. Three.js-based with @react-three/fiber.",
  "component": "Orb",
  "source": "https://github.com/elevenlabs/ui",
  "install": "npx @elevenlabs/cli@latest components add orb",
  "target_path": "client/src/components/ui/elevenlabs/orb.tsx",
  "peer_dependencies": ["three", "@react-three/fiber", "@react-three/drei"],
  "props": {
    "colors": {
      "type": "[string, string]",
      "default": "[\"#CADCFC\", \"#A0B9D1\"]",
      "description": "Gradient colors for orb surface"
    },
    "agentState": {
      "type": "\"idle\" | \"listening\" | \"talking\"",
      "description": "Controls animation intensity and pattern"
    },
    "getInputVolume": {
      "type": "() => number",
      "description": "Returns normalized mic input volume (0–1) for audio-reactive animation"
    },
    "getOutputVolume": {
      "type": "() => number",
      "description": "Returns normalized output volume (0–1) for audio-reactive animation"
    },
    "seed": {
      "type": "number",
      "default": "random",
      "description": "Consistent animation pattern across renders"
    },
    "height": {
      "type": "number",
      "default": 200,
      "description": "Height in pixels"
    },
    "width": {
      "type": "number",
      "default": 200,
      "description": "Width in pixels"
    }
  },
  "agent_state_mapping": {
    "idle": "Gentle floating, slow color shift",
    "listening": "Subtle pulsing, mic-reactive",
    "talking": "Active morphing, audio-reactive amplitude"
  },
  "marcela_colors": ["#9FBCA4", "#257D41"],
  "state_derivation": {
    "source": "useConversation() from @elevenlabs/react",
    "formula": "isSpeaking ? 'talking' : status === 'connected' ? 'listening' : 'idle'"
  },
  "skill_ref": ".claude/skills/elevenlabs/ui/orb.md"
}
