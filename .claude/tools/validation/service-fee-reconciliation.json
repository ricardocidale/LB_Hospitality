{
  "name": "service_fee_reconciliation",
  "description": "Verify that centralized service fees reconcile between property and company. Checks: (1) company service revenue = sum of property service fees, (2) vendor cost = revenue / (1 + markup) for each centralized category, (3) direct categories have zero vendor cost. Used by the verification pipeline.",
  "input_schema": {
    "type": "object",
    "properties": {
      "propertyFees": {
        "type": "array",
        "description": "Array of per-property fee breakdowns",
        "items": {
          "type": "object",
          "properties": {
            "propertyId": { "type": "number" },
            "feesByCategory": {
              "type": "object",
              "description": "Map of category name to fee amount",
              "additionalProperties": { "type": "number" }
            }
          }
        }
      },
      "companyServiceRevenue": {
        "type": "number",
        "description": "Total service revenue reported by the company"
      },
      "costOfServices": {
        "type": "number",
        "description": "Total vendor cost reported by the company"
      },
      "serviceTemplates": {
        "type": "array",
        "description": "Active service templates with model and markup",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "serviceModel": { "type": "string", "enum": ["centralized", "direct"] },
            "serviceMarkup": { "type": "number" }
          }
        }
      },
      "tolerance": {
        "type": "number",
        "description": "Acceptable variance in dollars (default: 1.00)",
        "default": 1.00
      }
    },
    "required": ["propertyFees", "companyServiceRevenue", "costOfServices", "serviceTemplates"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "passed": { "type": "boolean" },
      "checks": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "check": { "type": "string" },
            "expected": { "type": "number" },
            "actual": { "type": "number" },
            "variance": { "type": "number" },
            "passed": { "type": "boolean" }
          }
        }
      }
    }
  }
}
