{
  "name": "revpar_index",
  "description": "Compute STR-style competitive positioning indices for a hotel property. Calculates Market Penetration Index (MPI), Average Rate Index (ARI), and Revenue Generation Index (RGI) against the overall market and optionally a competitive set. An RGI > 1.0 means the property captures more than its fair share of market revenue.",
  "input_schema": {
    "type": "object",
    "properties": {
      "property_name": {
        "type": "string",
        "description": "Property identifier for reporting"
      },
      "room_count": {
        "type": "integer",
        "description": "Number of rooms"
      },
      "adr": {
        "type": "number",
        "description": "Property Average Daily Rate"
      },
      "occupancy": {
        "type": "number",
        "description": "Property occupancy as decimal (e.g. 0.72 = 72%)"
      },
      "market_adr": {
        "type": "number",
        "description": "Market-wide Average Daily Rate"
      },
      "market_occupancy": {
        "type": "number",
        "description": "Market-wide occupancy as decimal"
      },
      "comp_set_adr": {
        "type": "number",
        "description": "Competitive set Average Daily Rate (optional — for comp-set indices)"
      },
      "comp_set_occupancy": {
        "type": "number",
        "description": "Competitive set occupancy as decimal (optional)"
      }
    },
    "required": ["room_count", "adr", "occupancy", "market_adr", "market_occupancy"]
  }
}
