{
  "name": "stress_test",
  "description": "Apply adverse economic scenarios to a hotel property and measure impact on ADR, occupancy, RevPAR, NOI, DSCR, and exit valuation. Tests resilience against recession, demand shocks, expense spikes, and cap rate expansion. Each scenario independently shocks the base case metrics.",
  "input_schema": {
    "type": "object",
    "properties": {
      "property_name": {
        "type": "string",
        "description": "Property identifier for reporting"
      },
      "base_adr": {
        "type": "number",
        "description": "Base case Average Daily Rate"
      },
      "base_occupancy": {
        "type": "number",
        "description": "Base case occupancy as decimal (e.g. 0.70 = 70%)"
      },
      "base_noi": {
        "type": "number",
        "description": "Base case annual Net Operating Income"
      },
      "room_count": {
        "type": "integer",
        "description": "Number of rooms"
      },
      "annual_revenue": {
        "type": "number",
        "description": "Base case annual total revenue"
      },
      "annual_debt_service": {
        "type": "number",
        "description": "Annual debt service for DSCR calculation (0 for all-equity)"
      },
      "exit_cap_rate": {
        "type": "number",
        "description": "Base case exit cap rate as decimal"
      },
      "hold_period_years": {
        "type": "integer",
        "description": "Remaining hold period for terminal value calculation"
      },
      "scenarios": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "label": { "type": "string", "description": "Scenario name (e.g. 'Mild Recession')" },
            "adr_shock_pct": { "type": "number", "description": "ADR change as decimal (e.g. -0.10 = -10%)" },
            "occupancy_shock_pct": { "type": "number", "description": "Occupancy change as decimal" },
            "expense_shock_pct": { "type": "number", "description": "Expense increase as decimal" },
            "cap_rate_shock_bps": { "type": "number", "description": "Cap rate widening in basis points (e.g. 50 = +50bps)" },
            "revenue_shock_pct": { "type": "number", "description": "Direct revenue shock as decimal" }
          },
          "required": ["label", "adr_shock_pct", "occupancy_shock_pct"]
        },
        "description": "Array of stress scenarios to apply"
      }
    },
    "required": ["base_adr", "base_occupancy", "base_noi", "room_count", "annual_revenue", "exit_cap_rate", "hold_period_years", "scenarios"]
  }
}
