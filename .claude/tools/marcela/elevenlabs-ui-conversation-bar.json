{
  "name": "elevenlabs_ui_conversation_bar",
  "description": "Deterministic reference for the ElevenLabs Conversation Bar component — hybrid text + voice input bar for agent conversations.",
  "component": "ConversationBar",
  "source": "https://github.com/elevenlabs/ui",
  "install": "npx @elevenlabs/cli@latest components add conversation-bar",
  "target_path": "client/src/components/ui/elevenlabs/conversation-bar.tsx",
  "peer_dependencies": [],
  "props": {
    "onSend": { "type": "(text: string) => void", "description": "Called when user submits text" },
    "onVoiceToggle": { "type": "() => void", "description": "Mic button click handler" },
    "isVoiceActive": { "type": "boolean", "default": false, "description": "Voice input active state" },
    "placeholder": { "type": "string", "default": "Type a message..." },
    "disabled": { "type": "boolean", "default": false }
  },
  "features": {
    "text_mode": "Standard text input with Enter to send",
    "voice_mode": "Mic button toggles voice recording",
    "send_button": "Visible when text is entered",
    "keyboard": "Enter to send, Shift+Enter for newline",
    "auto_resize": "Input grows with content up to max height"
  },
  "glass_styling": "bg-black/20 backdrop-blur-xl border-t border-white/10",
  "integration_pattern": {
    "text_send": "conversation.sendUserMessage(text)",
    "voice_start": "conversation.startSession({ signedUrl })",
    "voice_stop": "conversation.endSession()"
  },
  "skill_ref": ".claude/skills/elevenlabs/ui/conversation-bar.md"
}
