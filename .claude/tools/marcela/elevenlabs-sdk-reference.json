{
  "name": "elevenlabs_sdk_reference",
  "description": "Deterministic reference for ElevenLabs SDK surface — React useConversation hook, web component attributes, callbacks, methods, state, connection types.",
  "react_hook": {
    "package": "@elevenlabs/react",
    "hook": "useConversation",
    "options": {
      "clientTools": "object — tool name → handler function",
      "overrides": {
        "agent.prompt.prompt": "string — override system prompt",
        "agent.firstMessage": "string — override first message",
        "agent.language": "string — ISO language code",
        "tts.voiceId": "string — override voice ID",
        "conversation.textOnly": "boolean — text-only mode"
      },
      "textOnly": "boolean — text-only mode (no microphone)",
      "serverLocation": "us | eu-residency | in-residency | global",
      "micMuted": "boolean — controlled mic mute state",
      "volume": "number 0-1 — controlled output volume"
    },
    "callbacks": [
      "onConnect", "onDisconnect", "onMessage", "onError",
      "onAudio", "onModeChange", "onStatusChange",
      "onCanSendFeedbackChange", "onDebug",
      "onUnhandledClientToolCall", "onVadScore", "onAudioAlignment"
    ],
    "methods": {
      "startSession": {
        "params": {
          "signedUrl": "string (for authenticated agents)",
          "agentId": "string (for public agents)",
          "connectionType": "websocket | webrtc",
          "userId": "string (optional end-user ID)"
        },
        "returns": "Promise<string> — conversationId"
      },
      "endSession": { "params": {}, "returns": "Promise<void>" },
      "sendUserMessage": { "params": { "text": "string" }, "returns": "void" },
      "sendContextualUpdate": { "params": { "text": "string" }, "returns": "void" },
      "sendFeedback": { "params": { "positive": "boolean" }, "returns": "void" },
      "sendUserActivity": { "params": {}, "returns": "void" },
      "setVolume": { "params": { "volume": "number 0-1" }, "returns": "void" },
      "changeInputDevice": { "params": { "sampleRate": "number", "format": "string", "inputDeviceId": "string" }, "returns": "Promise<void>" }
    },
    "state": {
      "status": "connected | disconnected",
      "isSpeaking": "boolean",
      "canSendFeedback": "boolean"
    }
  },
  "web_component": {
    "package": "@elevenlabs/convai-widget-core",
    "tag": "<elevenlabs-convai>",
    "core_attributes": ["agent-id", "url", "server-location", "variant", "dismissible"],
    "visual_attributes": ["avatar-image-url", "avatar-orb-color-1", "avatar-orb-color-2"],
    "text_attributes": ["action-text", "start-call-text", "end-call-text", "expand-text", "listening-text", "speaking-text"],
    "markdown_attributes": ["markdown-link-allowed-hosts", "markdown-link-include-www", "markdown-link-allow-http", "syntax-highlight-theme"],
    "override_attributes": ["override-language", "override-prompt", "override-first-message", "override-voice-id"],
    "runtime_attributes": ["dynamic-variables", "language"],
    "client_tools_event": "elevenlabs-convai:call"
  },
  "connection_types": {
    "websocket": {
      "auth": "Signed URL from /v1/convai/conversation/get-signed-url",
      "usage": "startSession({ signedUrl })"
    },
    "webrtc": {
      "auth": "Conversation Token",
      "usage": "startSession({ conversationToken, connectionType: 'webrtc' })"
    }
  },
  "modality_modes": {
    "voice_only": "Default — speech input only",
    "voice_text": "Voice + text — switchable during conversation",
    "chat_mode": "Text-only, no audio, 25x higher concurrency"
  }
}
