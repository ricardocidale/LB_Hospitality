{
  "name": "elevenlabs_ui_effects",
  "description": "Deterministic reference for ElevenLabs visual effects components — ShimmeringText (animated gradient text) and Matrix (dot-matrix display).",
  "components": {
    "ShimmeringText": {
      "description": "Animated text with gradient shimmer effects and viewport-triggered animations",
      "install": "npx @elevenlabs/cli@latest components add shimmering-text",
      "target_path": "client/src/components/ui/elevenlabs/shimmering-text.tsx",
      "peer_dependencies": ["framer-motion (already installed)"],
      "props": {
        "text": { "type": "string", "description": "Text to display" },
        "duration": { "type": "number", "default": 2, "description": "Shimmer duration in seconds" },
        "color": { "type": "string", "default": "#6B7280", "description": "Base text color" },
        "shimmerColor": { "type": "string", "default": "#3B82F6", "description": "Shimmer highlight color" },
        "startOnView": { "type": "boolean", "default": false, "description": "Start on scroll into view" },
        "once": { "type": "boolean", "default": false, "description": "Play only once" },
        "repeat": { "type": "boolean", "default": false, "description": "Repeat continuously" },
        "repeatDelay": { "type": "number", "default": 0, "description": "Delay between repeats (seconds)" }
      }
    },
    "Matrix": {
      "description": "Retro dot-matrix display with circular cells and smooth animations",
      "install": "npx @elevenlabs/cli@latest components add matrix",
      "target_path": "client/src/components/ui/elevenlabs/matrix.tsx",
      "peer_dependencies": []
    }
  },
  "source": "https://github.com/elevenlabs/ui",
  "marcela_colors": {
    "base": "#FFF9F5",
    "shimmer": "#9FBCA4"
  },
  "skill_ref": ".claude/skills/elevenlabs/ui/effects.md"
}
