{
  "name": "elevenlabs-widget-config",
  "description": "Deterministic reference for the ElevenLabs Conversational AI widget integration. Full attribute map, auth flow, admin config, voice IDs, runtime overrides, and client tool event.",
  "package": "@elevenlabs/convai-widget-core",
  "web_component": "<elevenlabs-convai>",
  "files": {
    "widget_component": "client/src/components/ElevenLabsWidget.tsx",
    "type_declarations": "client/src/elevenlabs-convai.d.ts",
    "layout_gating": "client/src/components/Layout.tsx",
    "signed_url_endpoint": "server/routes/admin/marcela.ts",
    "elevenlabs_integration": "server/integrations/elevenlabs.ts",
    "admin_tab": "client/src/components/admin/marcela/MarcelaTab.tsx",
    "admin_types": "client/src/components/admin/marcela/types.ts"
  },
  "db_field": {
    "table": "global_assumptions",
    "column": "marcela_agent_id",
    "ts_field": "marcelaAgentId",
    "type": "text",
    "default": ""
  },
  "api_endpoints": {
    "signed_url": {
      "method": "GET",
      "path": "/api/marcela/signed-url",
      "auth": "requireAuth (any logged-in user)",
      "response": { "signedUrl": "wss://..." },
      "upstream": "GET https://api.elevenlabs.io/v1/convai/conversation/get-signed-url?agent_id=<ID>"
    }
  },
  "voices": {
    "english": { "name": "Jessica", "id": "cgSgspJ2msm6clMCkdW9" },
    "portuguese": { "name": "Sarah", "id": "EXAVITQu4vr4xnSDxMaL" },
    "spanish": { "name": "configurable", "id": "set on ElevenLabs dashboard" }
  },
  "gating_conditions": [
    "showAiAssistant === true",
    "marcelaAgentId is non-empty",
    "tourActive === false",
    "promptVisible === false"
  ],
  "widget_attributes": {
    "core": {
      "url": "Signed WebSocket URL (for private/authenticated agents)",
      "agent-id": "Public agent ID (alternative to url)",
      "server-location": "us | eu-residency | in-residency | global",
      "variant": "expanded — widget display mode",
      "dismissible": "true | false — allow user to minimize"
    },
    "visual": {
      "avatar-image-url": "Custom avatar image URL",
      "avatar-orb-color-1": "Hex color — orb gradient start",
      "avatar-orb-color-2": "Hex color — orb gradient end"
    },
    "text_labels": {
      "action-text": "CTA button text (default: 'Need assistance?')",
      "start-call-text": "Start call button text",
      "end-call-text": "End call button text",
      "expand-text": "Expand widget text",
      "listening-text": "Listening state label",
      "speaking-text": "Speaking state label"
    },
    "markdown": {
      "markdown-link-allowed-hosts": "Domains where links clickable (* for all)",
      "markdown-link-include-www": "Allow www variants (default: true)",
      "markdown-link-allow-http": "Allow http:// links (default: true)",
      "syntax-highlight-theme": "dark | light | auto"
    },
    "runtime_overrides": {
      "override-language": "Override agent language (ISO code)",
      "override-prompt": "Override system prompt",
      "override-first-message": "Override first message",
      "override-voice-id": "Override voice ID"
    },
    "dynamic": {
      "dynamic-variables": "JSON string of key-value pairs for {{ var }} templates",
      "language": "Set initial language"
    }
  },
  "client_tools_event": {
    "event_name": "elevenlabs-convai:call",
    "registration": "widget.addEventListener('elevenlabs-convai:call', (event) => { event.detail.config.clientTools = { ... }; })"
  },
  "modality_modes": {
    "voice_only": "Default — speech input only",
    "voice_text": "Voice + text — toggle in dashboard Widget > Interface",
    "chat_mode": "Text-only, no audio, no microphone, 25x concurrency"
  }
}
