{
  "name": "elevenlabs_ui_voice_button",
  "description": "Deterministic reference for the ElevenLabs Voice Button component — microphone toggle for starting/stopping voice input.",
  "component": "VoiceButton",
  "source": "https://github.com/elevenlabs/ui",
  "install": "npx @elevenlabs/cli@latest components add voice-button",
  "target_path": "client/src/components/ui/elevenlabs/voice-button.tsx",
  "peer_dependencies": [],
  "props": {
    "isActive": { "type": "boolean", "default": false, "description": "Whether recording is active" },
    "onClick": { "type": "() => void", "description": "Toggle handler" },
    "disabled": { "type": "boolean", "default": false },
    "size": { "type": "\"sm\" | \"md\" | \"lg\"", "default": "md" },
    "variant": { "type": "\"default\" | \"outline\" | \"ghost\"", "default": "default" }
  },
  "visual_states": {
    "idle": "Mic icon, default colors",
    "active": "Pulsing animation, accent color",
    "disabled": "Muted colors, no interaction"
  },
  "accessibility": {
    "aria-label": "Toggle microphone (built-in)",
    "aria-pressed": "Reflects isActive state",
    "focus_ring": "Keyboard navigation support"
  },
  "connection_pattern": {
    "source": "useConversation() from @elevenlabs/react",
    "active_check": "conversation.status === 'connected'",
    "start": "conversation.startSession({ signedUrl })",
    "stop": "conversation.endSession()"
  },
  "skill_ref": ".claude/skills/elevenlabs/ui/voice-button.md"
}
