{
  "name": "elevenlabs_convai_api",
  "description": "Deterministic reference for ElevenLabs Conversational AI REST API endpoints. All require xi-api-key header. Includes admin proxy routes.",
  "base_url": "https://api.elevenlabs.io",
  "auth_header": "xi-api-key",
  "endpoints": {
    "get_signed_url": {
      "method": "GET",
      "path": "/v1/convai/conversation/get-signed-url",
      "query": { "agent_id": "string (required)" },
      "response": { "signed_url": "string (wss://...)" },
      "notes": "Single-use, temporary. Used for authenticated widget connections."
    },
    "get_agent": {
      "method": "GET",
      "path": "/v1/convai/agents/{agent_id}",
      "response": {
        "agent_id": "string",
        "name": "string",
        "conversation_config": {
          "agent": { "prompt": {}, "first_message": "string", "language": "string" },
          "tts": { "voice_id": "string", "model_id": "string" },
          "conversation": { "text_only": "boolean" }
        }
      }
    },
    "update_agent": {
      "method": "PATCH",
      "path": "/v1/convai/agents/{agent_id}",
      "body": {
        "conversation_config": {
          "agent": { "prompt": { "prompt": "string", "knowledge_base": [] }, "first_message": "string", "language": "string" },
          "tts": { "voice_id": "string" },
          "conversation": { "text_only": "boolean" }
        }
      }
    },
    "list_conversations": {
      "method": "GET",
      "path": "/v1/convai/conversations",
      "query": { "agent_id": "string (required)" },
      "response": { "conversations": [{ "conversation_id": "string", "agent_id": "string", "status": "string" }] }
    },
    "get_conversation": {
      "method": "GET",
      "path": "/v1/convai/conversations/{conversation_id}",
      "response": {
        "conversation_id": "string",
        "agent_id": "string",
        "status": "string",
        "transcript": [{ "role": "user | agent", "message": "string" }],
        "metadata": {}
      }
    },
    "delete_conversation": {
      "method": "DELETE",
      "path": "/v1/convai/conversations/{conversation_id}"
    },
    "create_kb_from_text": {
      "method": "POST",
      "path": "/v1/convai/knowledge-base/documents/create-from-text",
      "body": { "text": "string", "name": "string" },
      "response": { "id": "string", "name": "string" }
    },
    "create_kb_from_url": {
      "method": "POST",
      "path": "/v1/convai/knowledge-base/documents/create-from-url",
      "body": { "url": "string", "name": "string" },
      "response": { "id": "string", "name": "string" }
    },
    "create_kb_from_file": {
      "method": "POST",
      "path": "/v1/convai/knowledge-base/documents/create-from-file",
      "body": "multipart/form-data: file",
      "response": { "id": "string", "name": "string" },
      "notes": "Upload a file (PDF, TXT, etc.) to the knowledge base. Max 20MB."
    },
    "get_kb_document": {
      "method": "GET",
      "path": "/v1/convai/knowledge-base/documents/{document_id}",
      "response": { "id": "string", "name": "string", "status": "string" }
    },
    "delete_kb_document": {
      "method": "DELETE",
      "path": "/v1/convai/knowledge-base/documents/{document_id}"
    }
  },
  "admin_proxy_routes": {
    "description": "Server-side proxy endpoints that forward requests to ElevenLabs API with authentication. Used by the Admin > AI Agent tab.",
    "endpoints": {
      "get_agent_config": {
        "method": "GET",
        "path": "/api/admin/convai/agent",
        "description": "Fetch full agent configuration from ElevenLabs",
        "file": "server/routes/admin/marcela.ts"
      },
      "save_agent_prompt": {
        "method": "PATCH",
        "path": "/api/admin/convai/agent/prompt",
        "body": { "prompt": "string", "first_message": "string", "language": "string" },
        "description": "Save system prompt, first message, and language to ElevenLabs agent",
        "file": "server/routes/admin/marcela.ts"
      },
      "get_tools_status": {
        "method": "GET",
        "path": "/api/admin/convai/tools-status",
        "description": "Get all configured tools from ElevenLabs agent with type/description",
        "file": "server/routes/admin/marcela.ts"
      },
      "upload_kb_file": {
        "method": "POST",
        "path": "/api/admin/convai/knowledge-base/upload-file",
        "body": "multipart/form-data: file",
        "description": "Upload a file to ElevenLabs knowledge base (multer middleware)",
        "file": "server/routes/admin/marcela.ts"
      },
      "reindex_rag": {
        "method": "POST",
        "path": "/api/admin/marcela/reindex",
        "description": "Rebuild in-memory RAG embeddings from app data",
        "file": "server/routes/admin/marcela.ts"
      },
      "push_to_elevenlabs": {
        "method": "POST",
        "path": "/api/admin/marcela/push-to-elevenlabs",
        "description": "Push RAG knowledge base text to ElevenLabs KB",
        "file": "server/routes/admin/marcela.ts"
      },
      "configure_tools": {
        "method": "POST",
        "path": "/api/admin/marcela/configure-tools",
        "description": "Sync all 18 tools to ElevenLabs agent configuration",
        "file": "server/routes/admin/marcela.ts"
      },
      "signed_url": {
        "method": "GET",
        "path": "/api/marcela/signed-url",
        "description": "Generate signed URL for widget authentication",
        "file": "server/routes/admin/marcela.ts"
      }
    }
  },
  "knowledge_base_attachment": {
    "notes": "To attach a KB document to an agent, PATCH the agent with conversation_config.agent.prompt.knowledge_base array containing objects with { type: 'file', id: '<document_id>', name: '<name>' }",
    "implementation_file": "server/marcela-knowledge-base.ts"
  },
  "stt_endpoint": {
    "method": "POST",
    "path": "/v1/speech-to-text",
    "body": "multipart/form-data: file + model_id",
    "models": ["scribe_v1"]
  },
  "tts_websocket": {
    "url": "wss://api.elevenlabs.io/v1/text-to-speech/{voice_id}/stream-input",
    "query": { "model_id": "string", "output_format": "string" },
    "init_message": {
      "text": " ",
      "voice_settings": { "stability": 0.5, "similarity_boost": 0.8, "use_speaker_boost": false },
      "generation_config": { "chunk_length_schedule": [120, 160, 250, 290] }
    }
  },
  "server_files": {
    "api_key_provider": "server/integrations/elevenlabs.ts",
    "signed_url_route": "server/routes/admin/marcela.ts",
    "convai_helpers": "server/integrations/elevenlabs.ts",
    "agent_config_builder": "server/marcela-agent-config.ts",
    "knowledge_base": "server/marcela-knowledge-base.ts"
  }
}
