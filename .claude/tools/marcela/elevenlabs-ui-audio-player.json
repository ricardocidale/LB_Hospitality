{
  "name": "elevenlabs_ui_audio_player",
  "description": "Deterministic reference for the ElevenLabs Audio Player and Scrub Bar components — full playback controls for conversation recordings, TTS output, and audio content.",
  "components": {
    "AudioPlayer": {
      "description": "Full-featured audio player with controls",
      "install": "npx @elevenlabs/cli@latest components add audio-player",
      "props": {
        "src": { "type": "string", "description": "Audio file URL" },
        "title": { "type": "string", "description": "Track title" },
        "subtitle": { "type": "string", "description": "Artist/description" },
        "autoPlay": { "type": "boolean", "default": false },
        "onEnded": { "type": "() => void" },
        "className": { "type": "string" }
      }
    },
    "ScrubBar": {
      "description": "Standalone playback scrub bar with time display",
      "install": "npx @elevenlabs/cli@latest components add scrub-bar",
      "props": {
        "currentTime": { "type": "number", "description": "Seconds" },
        "duration": { "type": "number", "description": "Seconds" },
        "onSeek": { "type": "(time: number) => void" },
        "showTime": { "type": "boolean", "default": true }
      }
    }
  },
  "source": "https://github.com/elevenlabs/ui",
  "target_paths": {
    "audio_player": "client/src/components/ui/elevenlabs/audio-player.tsx",
    "scrub_bar": "client/src/components/ui/elevenlabs/scrub-bar.tsx"
  },
  "peer_dependencies": [],
  "features": ["Play/pause", "Progress scrub bar", "Volume control", "Duration display (mm:ss)", "Keyboard: Space play/pause, arrows seek"],
  "marcela_use_cases": [
    "Replay past conversations: src=/api/marcela/conversations/{id}/audio",
    "Play TTS previews: src=blob URL from streaming TTS",
    "Voice sample playback in voice selection UI"
  ],
  "skill_ref": ".claude/skills/elevenlabs/ui/audio-player.md"
}
