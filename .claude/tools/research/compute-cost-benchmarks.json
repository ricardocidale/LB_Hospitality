{
  "name": "compute_cost_benchmarks",
  "description": "Convert percentage cost rates into annual dollar amounts for a USALI-aligned cost breakdown. Use this to show the dollar impact of recommended cost rates.",
  "input_schema": {
    "type": "object",
    "properties": {
      "annual_room_revenue": { "type": "number", "description": "Annual room revenue in dollars" },
      "annual_total_revenue": { "type": "number", "description": "Annual total revenue in dollars" },
      "purchase_price": { "type": "number", "description": "Optional: property value for insurance/tax calculations" },
      "cost_rate_rooms": { "type": "number", "description": "Room department cost rate (0-1 decimal)" },
      "cost_rate_fb": { "type": "number", "description": "F&B cost rate (0-1 decimal)" },
      "cost_rate_admin": { "type": "number", "description": "Admin & general cost rate (0-1 decimal)" },
      "cost_rate_marketing": { "type": "number", "description": "Marketing cost rate (0-1 decimal)" },
      "cost_rate_property_ops": { "type": "number", "description": "Property operations cost rate (0-1 decimal)" },
      "cost_rate_utilities": { "type": "number", "description": "Utilities cost rate (0-1 decimal)" },
      "cost_rate_insurance": { "type": "number", "description": "Insurance rate on property value (0-1 decimal)" },
      "cost_rate_taxes": { "type": "number", "description": "Property tax rate on property value (0-1 decimal)" },
      "cost_rate_it": { "type": "number", "description": "IT cost rate (0-1 decimal)" },
      "cost_rate_ffe": { "type": "number", "description": "FF&E reserve rate (0-1 decimal)" },
      "cost_rate_other": { "type": "number", "description": "Other costs rate (0-1 decimal)" }
    },
    "required": ["annual_room_revenue", "annual_total_revenue"]
  }
}
