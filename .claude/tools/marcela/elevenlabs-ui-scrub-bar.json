{
  "name": "elevenlabs_ui_scrub_bar",
  "description": "Deterministic reference for the ElevenLabs Scrub Bar component — composable timeline scrubber for audio/video playback.",
  "components": {
    "ScrubBarContainer": {
      "description": "Root container — manages scrub state",
      "props": {
        "duration": { "type": "number", "required": true, "description": "Total duration of the timeline" },
        "value": { "type": "number", "required": true, "description": "Current value of the timeline" },
        "onScrub": { "type": "(time: number) => void", "description": "Callback when user scrubs" },
        "onScrubStart": { "type": "() => void", "description": "Callback when scrubbing starts" },
        "onScrubEnd": { "type": "() => void", "description": "Callback when scrubbing ends" }
      }
    },
    "ScrubBarTrack": {
      "description": "Track line — accepts standard HTMLDivElement attributes"
    },
    "ScrubBarProgress": {
      "description": "Progress fill — wrapper around Progress component"
    },
    "ScrubBarThumb": {
      "description": "Draggable scrub handle"
    },
    "ScrubBarTimeLabel": {
      "description": "Time display label"
    }
  },
  "source": "https://github.com/elevenlabs/ui",
  "install": "npx @elevenlabs/cli@latest components add scrub-bar",
  "target_path": "client/src/components/ui/elevenlabs/scrub-bar.tsx",
  "peer_dependencies": [],
  "composition_pattern": [
    "<ScrubBarContainer duration={180} value={42} onScrub={handleScrub}>",
    "  <ScrubBarTrack>",
    "    <ScrubBarProgress />",
    "    <ScrubBarThumb />",
    "  </ScrubBarTrack>",
    "  <ScrubBarTimeLabel />",
    "</ScrubBarContainer>"
  ],
  "skill_ref": ".claude/skills/elevenlabs/ui/audio-player.md"
}
