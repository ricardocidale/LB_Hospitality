{
  "name": "elevenlabs_ui_speech_input",
  "description": "Deterministic reference for the ElevenLabs Speech Input component — real-time STT input using Scribe v2. Voice-fill form fields, search bars, or text areas.",
  "components": {
    "SpeechInput": {
      "description": "Root — manages Scribe WebSocket connection",
      "props": {
        "getToken": { "type": "() => Promise<string>", "description": "Fetch Scribe auth token" },
        "onChange": { "type": "(data: TranscriptData) => void", "description": "Called on transcript update" },
        "modelId": { "type": "string", "default": "scribe_v2_realtime" },
        "languageCode": { "type": "string", "default": "en", "description": "ISO language code" },
        "commitStrategy": { "type": "\"manual\" | \"vad\"", "default": "vad" },
        "onError": { "type": "(error: Error) => void" }
      }
    },
    "SpeechInputRecordButton": {
      "description": "Mic toggle button (start/stop recording)"
    },
    "SpeechInputPreview": {
      "description": "Live transcription display",
      "props": {
        "placeholder": { "type": "string", "description": "Text shown before recording" }
      }
    },
    "TranscriptViewer": {
      "description": "Word-by-word highlighting synced to audio playback",
      "install": "npx @elevenlabs/cli@latest components add transcript-viewer",
      "props": {
        "transcript": { "type": "Word[]", "description": "Array of { text, start, end }" },
        "currentTime": { "type": "number", "description": "Current playback time (seconds)" }
      }
    }
  },
  "source": "https://github.com/elevenlabs/ui",
  "install": "npx @elevenlabs/cli@latest components add speech-input",
  "target_paths": {
    "speech_input": "client/src/components/ui/elevenlabs/speech-input.tsx",
    "transcript_viewer": "client/src/components/ui/elevenlabs/transcript-viewer.tsx"
  },
  "peer_dependencies": ["@elevenlabs/react"],
  "transcript_data_shape": {
    "text": "string — transcribed text",
    "isFinal": "boolean — whether segment is finalized",
    "confidence": "number — 0-1 confidence score"
  },
  "server_token_endpoint": {
    "method": "GET",
    "path": "/api/scribe/token",
    "auth": "requireAuth",
    "implementation": "client.speechToText.getToken()"
  },
  "supported_languages": ["en", "pt", "es"],
  "use_cases": [
    "Voice-fill property assumption form fields",
    "Voice search in property finder",
    "Voice notes on property details",
    "Real-time conversation transcription"
  ],
  "skill_ref": ".claude/skills/elevenlabs/ui/speech-input.md"
}
